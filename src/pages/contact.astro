---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NeonCard from "@/components/NeonCard.astro";
import GlowButton from "@/components/GlowButton.astro";
---

<BaseLayout title="Contact | Harder Labs" description="Get in touch with Harder Labs.">
  <section class="page-hero">
    <div class="container">
      <p class="muted">/contact</p>
      <h1 class="hero-title">Start a Conversation</h1>
      <p class="hero-subtitle">
        Let's build something together. Open a channel with us.
      </p>
      <p style="margin-top:0.65rem; color: var(--text-soft);">
        Whether you are interested in working with us, have a question about an order from one of our brands,
        or a technical inquiry for the lab, we're listening.
      </p>
      <div class="hero-actions" style="margin-top:1rem;">
        <GlowButton href="#brands">Say Hello</GlowButton>
      </div>
    </div>
  </section>

  <section id="brands" class="section">
    <div class="container grid grid-2">

      <NeonCard>
        <h2 style="font-size:1.35rem;">SharePuzzles</h2>
        <p style="margin-top:0.55rem; color: var(--text-soft);">Questions</p>
        <div class="hero-actions" style="margin-top:0.9rem;">
          <GlowButton href="mailto:info@sharepuzzles.com">info@sharepuzzles.com</GlowButton>
        </div>
      </NeonCard>

      <NeonCard>
        <h2 style="font-size:1.35rem;">Hill Country Gear</h2>
        <p style="margin-top:0.55rem; color: var(--text-soft);">Questions</p>
        <div class="hero-actions" style="margin-top:0.9rem;">
          <GlowButton href="mailto:info@hillcountrygear.com">info@hillcountrygear.com</GlowButton>
        </div>
      </NeonCard>

      <NeonCard>
        <h2 style="font-size:1.35rem;">Stellar Arcade</h2>
        <p style="margin-top:0.55rem; color: var(--text-soft);">Questions</p>
        <div class="hero-actions" style="margin-top:0.9rem;">
          <GlowButton href="mailto:info@stellararcade.com">info@stellararcade.com</GlowButton>
        </div>
      </NeonCard>

      <NeonCard>
        <h2 style="font-size:1.35rem;">General Lab Inquiries</h2>
        <p style="margin-top:0.55rem; color: var(--text-soft);">Partnerships &amp; Experiments</p>
        <div class="hero-actions" style="margin-top:0.9rem;">
          <GlowButton href="mailto:kevin@harder.dev">kevin@harder.dev</GlowButton>
        </div>
      </NeonCard>

      <NeonCard>
        <h2 style="font-size:1.35rem;">Legal &amp; Privacy</h2>
        <p style="margin-top:0.55rem; color: var(--text-soft);">Official Notices</p>
        <div class="hero-actions" style="margin-top:0.9rem;">
          <GlowButton href="mailto:kevin@harder.dev">kevin@harder.dev</GlowButton>
        </div>
      </NeonCard>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2">
      <NeonCard>
        <h2 style="font-size:1.35rem;">The Lab is Always Running</h2>
        <p style="margin-top:0.55rem;">
          We are a small, focused team. We typically respond to all inquiries within 24 business hours.
        </p>
      </NeonCard>

      <NeonCard>
        <h2 style="font-size:1.35rem;">Social Nodes</h2>
        <p style="margin-top:0.55rem;">Where we broadcast to.</p>
        <div class="hero-actions" style="margin-top:0.9rem;">
          <GlowButton href="https://www.linkedin.com/in/KevinHarder" target="_blank" variant="ghost">
            LinkedIn / @KevinHarder
          </GlowButton>
          <GlowButton href="https://github.com/harder" target="_blank" variant="ghost">
            GitHub / @harder
          </GlowButton>
          <GlowButton href="https://x.com/kevinharder" target="_blank" variant="ghost">
            X / @kevinharder
          </GlowButton>
        </div>
      </NeonCard>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <NeonCard>
        <h2 style="font-size:1.15rem;">Harder Labs HQ &mdash; Austin, Texas</h2>
        <p style="margin-top:0.55rem; color: var(--text-soft);">
          We are a digital-first studio. While we love our Austin community, we do not accept walk-ins
          or physical returns at our registered office. Please contact us via email for return instructions.
        </p>
      </NeonCard>
    </div>
  </section>
</BaseLayout>
