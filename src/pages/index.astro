---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NeonCard from "@/components/NeonCard.astro";
import GlowButton from "@/components/GlowButton.astro";
import TerminalPanel from "@/components/TerminalPanel.astro";
import LiveSignalsWidget from "@/components/islands/LiveSignalsWidget";

const workerBaseUrl = import.meta.env.PUBLIC_AI_WORKER_URL || "";
---

<BaseLayout>
  <section class="section">
    <div class="container split">
      <div>
        <p class="muted">harder.dev · Harder Labs · Austin, TX</p>
        <h1 class="hero-title">We build brands, run experiments, and ship what works.</h1>
        <p class="hero-subtitle">
          Harder Labs is a Texas company that builds niche e-commerce businesses and software
          products. 25+ years of engineering experience, a bias toward shipping, and a genuine
          curiosity about what AI can do for small teams.
        </p>
        <div class="hero-actions">
          <GlowButton href="/projects">View Projects</GlowButton>
          <GlowButton href="/signals" variant="ghost">Sub-Space Signals</GlowButton>
        </div>
      </div>

      <TerminalPanel title="current_state">
        <p>
          <strong style="color: var(--accent-primary)">AI Agents:</strong> Working with OpenAI Codex, GitHub CoPilot CLI, Claude Code, Gemini &amp; Antigravity, OpenClaw, and more!
        </p>
        <p>
          <strong style="color: var(--accent-secondary)">E-Commerce:</strong> Operating niche brands with real customers and real payment processing.
        </p>
        <p>
          <strong style="color: var(--accent-tertiary)">Community:</strong> Building platforms that bring people together, like puzzle exchanges and sharing networks.
        </p>
        <p>
          <strong style="color: var(--accent-primary)">Open Source:</strong> Sharing and contributing to open source tools.
        </p>
        <p>
          <strong style="color: var(--accent-secondary)">Mostly Harmless:</strong> We try not to break the internet.
        </p>
      </TerminalPanel>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-3">
      <NeonCard>
        <h2 style="font-size:1.2rem;">Build in Public</h2>
        <p style="margin-top:0.6rem;">We share the wins, the misses, and the occasional "what were we thinking?" moments.</p>
      </NeonCard>
      <NeonCard>
        <h2 style="font-size:1.2rem;">Purposeful Chaos</h2>
        <p style="margin-top:0.6rem;">Small experiments with clear exits beat giant "strategic initiatives" every time.</p>
      </NeonCard>
      <NeonCard>
        <h2 style="font-size:1.2rem;">Human-First</h2>
        <p style="margin-top:0.6rem;">
          Architecture should be understandable by a human who hasn't had their first cup of coffee yet.
        </p>
      </NeonCard>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2 class="section-title">The Signal</h2>
          <p class="section-subtitle">A filtered stream of engineering updates, curated so you don't have to doomscroll.</p>
        </div>
        <GlowButton href="/signals" variant="ghost">View All Signals</GlowButton>
      </div>
      <LiveSignalsWidget client:visible maxItems={4} workerBaseUrl={workerBaseUrl} />
    </div>
  </section>
</BaseLayout>
