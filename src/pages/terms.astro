---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Terms of Service | Harder Labs" description="Terms of Service for Harder Labs LLC and its affiliated brands.">
  <section class="page-hero">
    <div class="container">
      <p class="muted">/terms</p>
      <h1 class="hero-title">Terms of Service</h1>
      <p class="hero-subtitle">
        Last updated: March 1, 2026
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container legal-content">

      <h2>1. Agreement to Terms</h2>
      <p>
        By accessing or using any website, application, or service operated by Harder Labs LLC
        ("Harder Labs," "we," "us," or "our"), including harder.dev and any of our affiliated brand
        websites (collectively, the "Services"), you agree to be bound by these Terms of Service ("Terms").
