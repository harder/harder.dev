<style>
  .legal-content {
    max-width: 800px;
  }

  .legal-content h2 {
    font-size: 1.15rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    color: var(--accent-primary);
  }

  .legal-content p {
    margin-top: 0.5rem;
    line-height: 1.7;
    color: var(--text-soft);
  }

  .legal-content ul {
    margin: 0.5rem 0 0.5rem 1.2rem;
    color: var(--text-soft);
    line-height: 1.7;
  }

  .legal-content li {
    margin-top: 0.25rem;
  }
</style>
