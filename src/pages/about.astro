---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NeonCard from "@/components/NeonCard.astro";
import TerminalPanel from "@/components/TerminalPanel.astro";
---

<BaseLayout title="About | harder.dev" description="About Harder Labs LLC and Kevin Harder.">
  <section class="page-hero">
    <div class="container">
      <p class="muted">/about</p>
      <h1 class="hero-title">About harder.dev</h1>
      <p class="hero-subtitle">
        harder.dev is the primary web home for <strong>Harder Labs LLC</strong>, a Texas limited liability company.
        I still write in a direct personal voice, but this is also the official parent site for ventures, products,
        and experiments operating under the Harder Labs brand.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <NeonCard>
        <h2 style="font-size:1.5rem;">The Biological Entity</h2>
        <p style="margin-top:0.65rem;">
          I'm Kevin Harder, a software engineer building from Austin, Texas.
        </p>
        <p style="margin-top:0.65rem;">
          I have worked in software for 25+ years across startups and large enterprises, in roles from engineer to architect to engineering leader.
        </p>
        <p style="margin-top:0.65rem;">
          Today, I use Harder Labs LLC as an umbrella company for software and e-commerce projects that need real operational structure,
          including payments, customer support, bookkeeping, and compliance.
        </p>
        <p style="margin-top:0.65rem;">
          For my longer personal/career history, see
          <a class="inline-link" href="https://kevinharder.com" target="_blank" rel="noreferrer noopener">KevinHarder.com</a>.
        </p>
      </NeonCard>

      <TerminalPanel title="company_profile">
        <ul>
          <li><strong>Legal entity:</strong> Harder Labs LLC (Texas)</li>
          <li><strong>Brand:</strong> Harder Labs</li>
          <li><strong>Primary domain:</strong> harder.dev</li>
          <li><strong>Model:</strong> Parent/umbrella company for multiple projects and DBAs</li>
        </ul>
      </TerminalPanel>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Operating Projects</h2>
      <p class="section-subtitle" style="margin-top:0.8rem;">
        The following are examples of ventures being operated under the Harder Labs umbrella. Some are active businesses,
        some are in experimental phases, and some may operate under separate assumed-name (DBA) filings as needed.
      </p>
      <div class="grid grid-2" style="margin-top:1.2rem;">
        <NeonCard>
          <h3 style="font-size:1.1rem;">Current names in the portfolio</h3>
          <ul style="margin-top:0.7rem; padding-left:1.2rem; display:grid; gap:0.35rem;">
            <li>Hill Country Gear</li>
            <li>SharePuzzles</li>
            <li>Stellar Arcade</li>
            <li>Austin Puzzle Exchange</li>
          </ul>
        </NeonCard>
        <NeonCard>
          <h3 style="font-size:1.1rem;">How customer-facing entities work</h3>
          <p style="margin-top:0.55rem;">
            Customer transactions may appear under the specific project/brand name, the legal entity name (Harder Labs LLC),
            or both, depending on bank, payment processor, and statement descriptor constraints.
          </p>
          <p style="margin-top:0.55rem;">
            Where required, individual projects use their own official DBA filings and project-specific legal pages.
          </p>
        </NeonCard>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">The Engine Room</h2>
      <p class="section-subtitle" style="margin-top:0.8rem;">
        This site is static-first by design, with dynamic behavior only where it provides value.
        Because the best way to ensure a page works is to not make the server do anything when someone visits.
      </p>
      <div class="grid grid-3" style="margin-top:1.2rem;">
        <NeonCard>
          <h3 style="font-size:1.1rem;">Static Stability</h3>
          <p style="margin-top:0.55rem;">
            Built with <a class="inline-link" href="https://astro.build" target="_blank" rel="noreferrer noopener">Astro</a> and
            <a class="inline-link" href="https://www.typescriptlang.org/" target="_blank" rel="noreferrer noopener">TypeScript</a>
            for static generation, clean routing, and minimal JavaScript by default.
          </p>
        </NeonCard>
        <NeonCard>
          <h3 style="font-size:1.1rem;">Occasional Hydration</h3>
          <p style="margin-top:0.55rem;">
            I use <a class="inline-link" href="https://docs.astro.build/en/concepts/islands/" target="_blank" rel="noreferrer noopener">Astro islands</a>
            for features that actually need interactivity, with <a class="inline-link" href="https://preactjs.com" target="_blank" rel="noreferrer noopener">Preact</a>
            hydrating only where needed.
          </p>
        </NeonCard>
        <NeonCard>
          <h3 style="font-size:1.1rem;">Feed + AI Processing Pipeline</h3>
          <p style="margin-top:0.55rem;">
            Trusted feeds are summarized with local browser AI when possible, or
            <a class="inline-link" href="https://developers.cloudflare.com/workers/" target="_blank" rel="noreferrer noopener">Cloudflare Workers</a>.
          </p>
        </NeonCard>
      </div>
    </div>
  </section>
</BaseLayout>
