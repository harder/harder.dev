---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NeonCard from "@/components/NeonCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Projects | Harder Labs" description="Brands and ventures operated by Harder Labs.">
  <section class="page-hero">
    <div class="container">
      <p class="muted">/projects</p>
      <h1 class="hero-title">Our Ventures</h1>
      <p class="hero-subtitle">
        Brands, platforms, and experiments actively built and operated by Harder Labs.
        Each one is a real business helping real customers enjoy their lives.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2">
      {
        projects.map((project) => (
          <NeonCard>
            <h2 style="font-size:1.2rem;">
              <a class="project-title-link" href={project.data.url} target="_blank" rel="noreferrer noopener">
                {project.data.name}
              </a>
            </h2>
            <p style="margin-top:0.6rem;">{project.data.summary}</p>
            {project.data.details.map((detail) => (
              <p style="margin-top:0.6rem;">{detail}</p>
            ))}
          </NeonCard>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .project-title-link {
    color: var(--text-main);
    text-decoration: none;
    border-bottom: 1px dashed rgba(120, 198, 255, 0.45);
  }

  .project-title-link:hover {
    color: var(--accent-primary);
    border-bottom-color: var(--accent-primary);
  }
</style>
