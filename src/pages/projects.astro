---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NeonCard from "@/components/NeonCard.astro";
import TagChip from "@/components/TagChip.astro";

const projects = [
  { name: "Hill Country Gear", url: "https://hillcountrygear.com" },
  { name: "Stellar Arcade", url: "https://stellararcade.com" },
  { name: "SharePuzzles", url: "https://sharepuzzles.com" },
  { name: "Austin Puzzle Exchange", url: "https://austinpuzzles.com" }
];
---

<BaseLayout title="Projects | Harder Labs" description="Brands and ventures operated by Harder Labs — niche e-commerce, community platforms, and software experiments.">
  <section class="page-hero">
    <div class="container">
      <p class="muted">/projects</p>
      <h1 class="hero-title">Our Ventures</h1>
      <p class="hero-subtitle">
        Brands, platforms, and experiments actively built and operated by Harder Labs.
        Each one is a real business with real customers — not a side project in a drawer.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2">
      <NeonCard>
        <h2 style="font-size:1.2rem;">
          <a class="project-title-link" href={projects[0].url} target="_blank" rel="noreferrer noopener">
            {projects[0].name}
          </a>
        </h2>
        <div style="margin-top:0.45rem;"><TagChip>E-Commerce</TagChip><TagChip>DBA</TagChip></div>
        <p style="margin-top:0.6rem;">
          Texas Hill Country: Adventure. Leisure. State of Mind. Hill Country Gear provides what you need to enjoy it all.
          An e-commerce and operations platform focused on clean catalog workflows and maintainable systems.
        </p>
      </NeonCard>

      <NeonCard>
        <h2 style="font-size:1.2rem;">
          <a class="project-title-link" href={projects[1].url} target="_blank" rel="noreferrer noopener">
            {projects[1].name}
          </a>
        </h2>
        <div style="margin-top:0.45rem;"><TagChip>E-Commerce</TagChip><TagChip>DBA</TagChip></div>
        <p style="margin-top:0.6rem;">
          Stellar Arcade is your go-to destination for retro electronics, sci-fi & fantasy collectables, and trading card games.
          Explore our curated marketplace, discover rare finds, and dive into expert knowledge shared on our blog.
        </p>
      </NeonCard>

      <NeonCard>
        <h2 style="font-size:1.2rem;">
          <a class="project-title-link" href={projects[2].url} target="_blank" rel="noreferrer noopener">
            {projects[2].name}
          </a>
        </h2>
        <div style="margin-top:0.45rem;"><TagChip>Platform</TagChip><TagChip>DBA</TagChip></div>
        <p style="margin-top:0.6rem;">
          A worldwide platform to help people share puzzles and find others who love puzzles.
          A community resource that brings people together and helps them save money.
        </p>
      </NeonCard>

      <NeonCard>
        <h2 style="font-size:1.2rem;">
          <a class="project-title-link" href={projects[3].url} target="_blank" rel="noreferrer noopener">
            {projects[3].name}
          </a>
        </h2>
        <div style="margin-top:0.45rem;"><TagChip>Community</TagChip><TagChip>DBA</TagChip></div>
        <p style="margin-top:0.6rem;">
          Building community and fostering a love for puzzles through our neighborhood exchange program.
          Share your love of puzzles and enjoy new challenges without the cost.
        </p>
      </NeonCard>
    </div>
  </section>
</BaseLayout>

<style>
  .project-title-link {
    color: var(--text-main);
    text-decoration: none;
    border-bottom: 1px dashed rgba(120, 198, 255, 0.45);
  }

  .project-title-link:hover {
    color: var(--accent-primary);
    border-bottom-color: var(--accent-primary);
  }
</style>
